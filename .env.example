# Point to your Node backend (must include `/api/v1` if the server mounts routes there).
# Local: http://localhost:5000/api/v1
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_APP_NAME=Tiknova
# `false` = login calls real backend (`useAdminLoginMutation`); use after `npm run bootstrap:admin`
VITE_ENABLE_MOCK_API=false
